{
  "expo": {
    "name": "FinMate AI",
    "slug": "finmate-ai",
    "scheme": "finmateai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "web": {
      "output": "server"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
